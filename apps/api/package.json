{
  "name": "@portl/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "prisma generate && npm run build --workspace=@portl/shared && tsc",
    "check-types": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "npm run test:seed && npm run test:auth && npm run test:rbac && npm run test:visitor-create && npm run test:state-machine && npm run test:lock && npm run test:socket && npm run test:idempotency && npm run test:notice && npm run test:poll && npm run test:complaint && npm run test:amenity",
    "test:auth": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/auth.test.ts",
    "test:rbac": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/rbac.test.ts",
    "test:seed": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/seed.test.ts",
    "test:visitor-create": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/visitor-create.test.ts",
    "test:state-machine": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/state-machine.test.ts",
    "test:lock": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/lock.test.ts",
    "test:socket": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/socket.test.ts",
    "test:idempotency": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/idempotency.test.ts",
    "test:notice": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/notice.test.ts",
    "test:poll": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/poll.test.ts",
    "test:complaint": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/complaint.test.ts",
    "test:amenity": "cross-env NODE_ENV=test node --test --import tsx/esm src/test/amenity.test.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "prisma": "^7.8.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "@portl/shared": "*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.9",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^6.1.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "socket.io": "^4.8.3"
  }
}
